{
  "name": "jfilebrowser",
  "displayName": "JFileBrowser",
  "description": "A file browser with integrated search for filtering files and folders by name",
  "version": "0.2.8",
  "publisher": "jfilebrowser",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "jfilebrowser.focusSearch",
        "title": "JFileBrowser: Focus Search"
      }
    ],
    "keybindings": [
      {
        "command": "jfilebrowser.focusSearch",
        "key": "ctrl+alt+p",
        "when": "workspaceFolderCount > 0"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "jfilebrowserContainer",
          "title": "JFileBrowser",
          "icon": "media/logo.svg"
        }
      ]
    },
    "views": {
      "jfilebrowserContainer": [
        {
          "type": "webview",
          "id": "jfilebrowser",
          "name": "Files",
          "when": "workspaceFolderCount > 0"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "release": "node scripts/release.js",
    "package": "node scripts/release.js"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0"
  }
}
